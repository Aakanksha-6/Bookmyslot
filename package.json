{
  "name": "bookmyslot",
  "version": "1.0.0",
  "description": "BookMySlot — IT Seminar Hall Booking System",
  "main": "dist/server.js",
  "scripts": {
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "tsc -p tsconfig.client.json",
    "build": "npm run build:server && npm run build:client",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "mongoose": "^7.8.0"
  },
  "devDependencies": {
    "@types/angular": "^1.8.9",
    "@types/angular-route": "^1.7.6",
    "@types/express": "^4.17.19",
    "@types/node": "^20.11.0",
    "@types/cors": "^2.8.18",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
