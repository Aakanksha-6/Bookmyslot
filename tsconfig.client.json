{
  "compilerOptions": {
    "target": "es5",
    "module": "none",
    "noImplicitAny": false,
    "removeComments": true,
    "preserveConstEnums": true,
    "sourceMap": false,
    "skipLibCheck": true,
    "types": ["angular", "angular-route"],
    "lib": ["es5", "dom"],
    "outFile": "public/app.js"
  },
  "include": ["public/app.ts"]
}
